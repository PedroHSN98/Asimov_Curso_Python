    "#functools.cache\n",
    "import functools\n",
    "\n",
    "def fatorial(n):\n",
    "    print(f'Valor de n: {n}')\n",
    "    if n == 1:\n",
    "        return n \n",
    "    return n * fatorial(n-1)\n",
    "\n",
    "fatorial(4)\n",
    "\n"
   ]
  }
