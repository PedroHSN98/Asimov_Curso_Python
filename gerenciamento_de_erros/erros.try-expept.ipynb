    "### Lindando com erros com blocos try/except"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6bae2669",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "10.0\n"
     ]
    }
   ],
   "source": [
    "try:\n",
    "    x = float(input('Digite um número:'))\n",
    "    y = float(input('Digite um divisor: '))\n",
    "    resultado = x / y\n",
    "    #divisor de 0 da erro\n",
    "except:\n",
    "    print('Error')\n",
    "else:\n",
    "    print(resultado)\n",
    "finally:\n",
    "    print('Final do código')\n"
   ]
  }
